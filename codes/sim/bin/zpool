#!/usr/bin/env python3
"""Fake `zpool` for the b2ctl simulation harness.

Reads/writes sim state.json. Supports the subset of zpool that b2ctl issues:
list / status / replace / add / attach / detach / remove / create /
labelclear / online / offline / version.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
import _simstate as S  # noqa: E402


def _present(state, name):
    d = S.disk_by_name(state, name)
    return bool(d and d.get("present"))


def _down(state, pool, name):
    """A member counts as 'down' for redundancy if physically absent OR the
    operator offlined it (F-118) — either way it is not protecting the vdev."""
    return (not _present(state, name)) or (name in pool.get("offline", []))


def _member_state(state, pool, name):
    if name in pool.get("offline", []):
        return "OFFLINE"
    return "ONLINE" if _present(state, name) else "REMOVED"


def _vdev_label(pool):
    return {"raidz1": "raidz1-0", "raidz2": "raidz2-0",
            "mirror": "mirror-0", "stripe": None}.get(pool["type"])


def _pool_health(state, pool):
    if pool.get("type") == "raid10":
        # raid10 survives as long as no single mirror group loses BOTH legs; one
        # down leg anywhere is DEGRADED, not SUSPENDED (F-065).
        groups = S.raid10_groups(pool)
        if any(all(_down(state, pool, m) for m in g) for g in groups):
            return "SUSPENDED"
        if any(_down(state, pool, m) for m in pool["members"]) or pool.get("replacements"):
            return "DEGRADED"
        return "ONLINE"
    down = [m for m in pool["members"] if _down(state, pool, m)]
    if len(down) > S.parity_of(pool):
        return "SUSPENDED"
    if down or pool.get("replacements"):
        return "DEGRADED"
    return "ONLINE"


# --------------------------------------------------------------------------- #
# list
# --------------------------------------------------------------------------- #

def cmd_list(args, state):
    # b2ctl: zpool list -H -o name,size,alloc,free,health,frag,cap
    if "-H" in args:
        for p in state["pools"]:
            health = _pool_health(state, p)
            size = "952G" if p["name"] == "rpool" else "2.72T"
            print("\t".join([p["name"], size, "1.71G", size, health, "0%", "0%"]))
        return 0
    # zpool list -v (snapshot) — minimal
    print("NAME   SIZE  ALLOC  FREE  CKPOINT  EXPANDSZ  FRAG  CAP  DEDUP  HEALTH  ALTROOT")
    for p in state["pools"]:
        print(f"{p['name']}  2.72T  1.71G  2.72T  -  -  0%  0%  1.00x  {_pool_health(state, p)}  -")
    return 0


# --------------------------------------------------------------------------- #
# status
# --------------------------------------------------------------------------- #

def _render_aux_and_spares(state, pool, lines):
    for aux in ("log", "cache"):
        devs = pool.get(aux, [])
        if devs:
            lines.append(f"\t{aux}")
            for dv in devs:
                st = "ONLINE" if _present(state, dv) else "REMOVED"
                lines.append(f"\t    /dev/{dv:<24} {st}")
    if pool["spares"]:
        lines.append("\tspares")
        inuse = {r["spare"] for r in pool.get("replacements", [])}
        for s in pool["spares"]:
            st = "INUSE     currently in use" if s in inuse else "AVAIL"
            lines.append(f"\t    /dev/{s:<24} {st}")


def _render_repl(m, rec, state, pool, indent):
    """Render a replacing-N (fresh disk) or spare-N (hot spare) sub-vdev holding
    the old member + the incoming device, exactly like real ZFS keeps until the
    resilver finishes / the old leg is detached (F-117)."""
    kind = rec.get("kind", "spare")
    label = "replacing-0" if kind == "replacing" else "spare-0"
    old_state = _member_state(state, pool, m)
    return [f"{indent}{label:<27} DEGRADED",
            f"{indent}  /dev/{m:<20} {old_state}",
            f"{indent}  /dev/{rec['spare']:<20} ONLINE"]


def _render_status(state, pool):
    health = _pool_health(state, pool)
    lines = [f"  pool: {pool['name']}", f" state: {health}"]

    # scan line: pct is time-derived, so reads never advance it (F-116)
    res = pool.get("resilver")
    if res is not None:
        pct = S.resilver_pct(res)
        if pct >= 100:
            lines.append("  scan: resilvered 590M in 00:00:02 with 0 errors on Tue Jan  1 00:00:00 2030")
        else:
            lines.append("  scan: resilver in progress since Tue Jan  1 00:00:00 2030")
            lines.append(f"\t590M scanned, {pct}.0% done, 00:00:02 to go")

    lines += ["config:", "", "\tNAME                              STATE     READ WRITE CKSUM"]
    lines.append(f"\t{pool['name']:<33} {health}")

    repl = {r["removed"]: r for r in pool.get("replacements", [])}

    # raid10: render each mirror group as its own mirror-N sub-vdev so b2ctl's
    # topology parser classifies the pool as 'mirror', not 'stripe' (F-065).
    if pool.get("type") == "raid10":
        for gi, group in enumerate(S.raid10_groups(pool)):
            gstate = "DEGRADED" if any(_down(state, pool, m) for m in group) else "ONLINE"
            lines.append(f"\t  mirror-{gi:<25} {gstate}")
            for m in group:
                if m in repl:
                    lines += _render_repl(m, repl[m], state, pool, "\t    ")
                else:
                    lines.append(f"\t    /dev/{m:<22} {_member_state(state, pool, m)}")
        _render_aux_and_spares(state, pool, lines)
        lines.append("")
        lines.append("errors: No known data errors")
        return "\n".join(lines)

    vlabel = _vdev_label(pool)
    indent_member = "\t    " if vlabel else "\t  "
    if vlabel:
        vstate = "DEGRADED" if (health != "ONLINE") else "ONLINE"
        lines.append(f"\t  {vlabel:<31} {vstate}")

    for m in pool["members"]:
        if m in repl:
            lines += _render_repl(m, repl[m], state, pool, indent_member)
        else:
            lines.append(f"{indent_member}/dev/{m:<24} {_member_state(state, pool, m)}")

    _render_aux_and_spares(state, pool, lines)

    lines.append("")
    lines.append("errors: No known data errors")
    return "\n".join(lines)


def cmd_status(args, state):
    pos = [a for a in args if not a.startswith("-")]
    targets = [pool for pool in state["pools"] if not pos or pool["name"] in pos]
    changed = False
    for p in targets:
        # F-116: reads are side-effect-free — progress is time-derived, not
        # bumped per read. The ONLY persisted transition is the one-time
        # completion of a fresh-disk replace: real ZFS auto-detaches the old
        # member from a replacing-N group when the resilver finishes (F-117).
        # Collapse BEFORE rendering so the completing read is self-consistent.
        res = p.get("resilver")
        if res is not None and S.resilver_pct(res) >= 100:
            for r in list(p.get("replacements", [])):
                if r.get("kind") == "replacing":
                    p["members"] = [r["spare"] if m == r["removed"] else m
                                    for m in p["members"]]
                    p["replacements"].remove(r)
                    changed = True
    print("\n".join(_render_status(state, p) for p in targets))
    if changed:
        S.save(state)
    return 0


# --------------------------------------------------------------------------- #
# mutating
# --------------------------------------------------------------------------- #

def _strip_flags(args):
    return [a for a in args if not a.startswith("-")]


def cmd_replace(args, state):
    a = _strip_flags(args)               # pool old new
    if len(a) < 3:
        return 1
    pool = S.pool_of(state, a[0]) or next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool:
        print("cannot open pool", file=sys.stderr); return 1
    old = a[1].replace("/dev/", "")
    new = a[2].replace("/dev/", "")
    old = (S.disk_by_token(state, old) or {}).get("name", old)
    new = (S.disk_by_token(state, new) or {}).get("name", new)
    # F-117: model the INTERMEDIATE state real ZFS keeps until the resilver
    # finishes / the old leg is detached, instead of finalizing instantly. Old
    # stays in members under a spare-N (hot spare) or replacing-N (fresh disk)
    # sub-vdev; the completion is handled by detach (spare) or cmd_status
    # auto-collapse at pct>=100 (replacing).
    pool.setdefault("replacements", [])
    pool["replacements"] = [r for r in pool["replacements"] if r["removed"] != old]
    kind = "spare" if new in pool.get("spares", []) else "replacing"
    pool["replacements"].append({"removed": old, "spare": new, "kind": kind})
    pool["resilver"] = S.resilver_seed()
    S.save(state)
    return 0


def cmd_add(args, state):
    a = _strip_flags(args)               # pool [spare|mirror] devs...
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool:
        return 1
    kind = a[1] if len(a) >= 2 else ""
    if kind in ("cache", "log"):
        key = kind
        pool.setdefault(key, [])
        for dev in a[2:]:
            if dev == "mirror":
                continue
            name = dev.replace("/dev/", "")
            name = (S.disk_by_token(state, name) or {}).get("name", name)
            if name not in pool[key]:
                pool[key].append(name)
    elif kind == "spare":
        for dev in a[2:]:
            name = dev.replace("/dev/", "")
            name = (S.disk_by_token(state, name) or {}).get("name", name)
            if name not in pool["spares"]:
                pool["spares"].append(name)
    elif kind == "mirror":
        for dev in a[2:]:
            name = dev.replace("/dev/", "")
            if name not in pool["members"]:
                pool["members"].append(name)
    S.save(state)
    return 0


def cmd_attach(args, state):
    a = _strip_flags(args)               # pool existing new
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool or len(a) < 3:
        return 1
    new = a[2].replace("/dev/", "")
    if new not in pool["members"]:
        pool["members"].append(new)
    pool["resilver"] = S.resilver_seed()
    S.save(state)
    return 0


def cmd_detach(args, state):
    a = _strip_flags(args)               # pool dev
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool or len(a) < 2:
        return 1
    raw = a[1].replace("/dev/", "")
    dev = (S.disk_by_token(state, raw) or {}).get("name", raw)
    # detaching a removed-old token finalizes the spare into the vdev
    for r in list(pool.get("replacements", [])):
        if r["removed"] == dev:
            pool["members"] = [r["spare"] if m == dev else m for m in pool["members"]]
            pool["spares"] = [s for s in pool["spares"] if s != r["spare"]]
            pool["replacements"].remove(r)
            S.save(state); return 0
    # F-117: a token that is neither a lingering replacement's old leg nor a
    # current member/spare is not in the pool — real zpool errors, so must sim,
    # or a wrong-token detach regression would silently 'pass' the harness.
    if dev not in pool["members"] and dev not in pool["spares"]:
        print(f"cannot detach {a[1]}: no such device in pool", file=sys.stderr)
        return 1
    pool["members"] = [m for m in pool["members"] if m != dev]
    pool["spares"] = [s for s in pool["spares"] if s != dev]
    S.save(state)
    return 0


def cmd_remove(args, state):
    a = _strip_flags(args)               # pool dev  (offload spare)
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool or len(a) < 2:
        return 1
    dev = a[1].replace("/dev/", "")
    dev = (S.disk_by_token(state, dev) or {}).get("name", dev)
    pool["spares"] = [s for s in pool["spares"] if s != dev]
    pool["members"] = [m for m in pool["members"] if m != dev]
    pool["cache"] = [c for c in pool.get("cache", []) if c != dev]
    pool["log"] = [g for g in pool.get("log", []) if g != dev]
    S.save(state)
    return 0


def cmd_create(args, state):
    # Drop flags AND `-o/-O` property VALUES (k=v args don't start with '-').
    a = [x for x in _strip_flags(args) if "=" not in x]   # name [raidtype] devs...
    if not a:
        return 1
    name = a[0]
    rest = a[1:]
    _vkw = ("mirror", "raidz1", "raidz2", "raidz3")
    rtype = "stripe"
    if rest and rest[0] in _vkw:
        # raid10 repeats `mirror`; record raid10 when >1 mirror group, else the keyword.
        rtype = "raid10" if (rest[0] == "mirror" and rest.count("mirror") > 1) else rest[0]
    devs = [d for d in rest if d not in _vkw]          # drop vdev keyword tokens
    members = [(S.disk_by_token(state, d.replace("/dev/", "")) or {}).get("name", d.replace("/dev/", "")) for d in devs]
    # raid10: record the mirror groups (pairs in order) so status renders
    # mirror-0/mirror-1 and health is group-aware (F-065).
    groups = ([members[i:i + 2] for i in range(0, len(members), 2)]
              if rtype == "raid10" else None)
    state["pools"].append({"name": name, "type": rtype, "members": members,
                           "groups": groups,
                           "spares": [], "replacements": [], "cache": [], "log": [],
                           "resilver": None})
    for m in members:
        d = S.disk_by_name(state, m)
        if d:
            d["dirty"] = False
    S.save(state)
    return 0


def cmd_destroy(args, state):
    a = _strip_flags(args)               # destroy <pool>
    if not a:
        return 1
    name = a[0]
    before = len(state["pools"])
    state["pools"] = [p for p in state["pools"] if p.get("name") != name]
    if len(state["pools"]) == before:
        print(f"cannot open '{name}': no such pool", file=sys.stderr)
        return 1
    S.save(state)
    return 0


def cmd_offline(args, state):
    a = _strip_flags(args)               # pool dev
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool or len(a) < 2:
        return 1
    dev = a[1].replace("/dev/", "")
    dev = (S.disk_by_token(state, dev) or {}).get("name", dev)
    if dev not in pool["members"]:
        print(f"cannot offline {a[1]}: no such device in pool", file=sys.stderr)
        return 1
    off = pool.setdefault("offline", [])
    if dev not in off:
        off.append(dev)                  # F-118: member now renders OFFLINE, pool DEGRADED
    S.save(state)
    return 0


def cmd_online(args, state):
    a = _strip_flags(args)               # pool dev
    pool = next((p for p in state["pools"] if p["name"] == a[0]), None)
    if not pool or len(a) < 2:
        return 1
    dev = a[1].replace("/dev/", "")
    dev = (S.disk_by_token(state, dev) or {}).get("name", dev)
    pool["offline"] = [m for m in pool.get("offline", []) if m != dev]
    S.save(state)
    return 0


def cmd_labelclear(args, state):
    a = _strip_flags(args)
    if a:
        d = S.disk_by_token(state, a[0].replace("/dev/", ""))
        if d:
            d["dirty"] = False
            S.save(state)
    return 0


def main():
    argv = sys.argv[1:]
    if not argv:
        return 1
    sub, args = argv[0], argv[1:]
    state = S.load()
    table = {
        "list": cmd_list, "status": cmd_status, "replace": cmd_replace,
        "add": cmd_add, "attach": cmd_attach, "detach": cmd_detach,
        "remove": cmd_remove, "create": cmd_create, "destroy": cmd_destroy,
        "labelclear": cmd_labelclear,
        "offline": cmd_offline, "online": cmd_online,     # F-118: real state change
    }
    if sub == "version":
        print("zfs-2.4.2-sim"); return 0
    if sub in ("clear", "trim", "scrub", "set"):   # genuinely no-ops for the sim
        return 0
    fn = table.get(sub)
    if fn is None:
        print(f"unrecognized command '{sub}'", file=sys.stderr); return 2
    return fn(args, state)


if __name__ == "__main__":
    sys.exit(main())
