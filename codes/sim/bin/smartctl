#!/usr/bin/env python3
"""Fake `smartctl -a /dev/sdX` — emits ATA-format SMART from sim state."""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
import _simstate as S  # noqa: E402


def main():
    argv = sys.argv[1:]
    if "--version" in argv:
        print("smartctl 7.5 2025-04-30 r5714 [x86_64-linux-sim] (local build)")
        return 0
    dev = next((a for a in argv if a.startswith("/dev/")), None)
    if not dev:
        return 1
    state = S.load()
    # `-d megaraid,<DID>` reads a PD behind the PERC VD via passthrough — resolve
    # the DID to the same drive the fake perccli assigned it (F-115), NOT the VD
    # block device named on the command line.
    did = next((a.split(",", 1)[1] for a in argv if a.startswith("megaraid,")), None)
    if did is not None and did.isdigit():
        pds = S.raid_pds(state)
        d = pds[int(did)] if int(did) < len(pds) else None
        if not d:
            return 2
    else:
        d = S.disk_by_name(state, dev)
        if not d or not d.get("present"):
            return 2  # no such device → b2ctl marks NOREAD

    # `smartctl -t long|short <dev>` — start a (fake) self-test, return immediately.
    if "-t" in argv:
        kind = argv[argv.index("-t") + 1] if argv.index("-t") + 1 < len(argv) else "long"
        print(f"Sending command: \"Execute SMART {kind.capitalize()} self-test routine "
              "immediately in off-line mode\".")
        print("Drive command \"Execute SMART ... self-test\" successful.")
        print("Testing has begun.")
        return 0

    print("smartctl 7.5 2025-04-30 r5714 [x86_64-linux-sim] (local build)")
    print("")
    # NVMe drives report in a different format (smart._parse_nvme keys on
    # "NVMe" + "SMART/Health Information").
    if d.get("tran") == "nvme" or dev.startswith("/dev/nvme"):
        print("=== START OF INFORMATION SECTION ===")
        print(f"Model Number:                       {d['model']}")
        print(f"Serial Number:                      {d['serial']}")
        print("=== START OF SMART DATA SECTION ===")
        print("SMART overall-health self-assessment test result: PASSED")
        print("")
        print("SMART/Health Information (NVMe Log 0x02)")
        print(f"Percentage Used:                    {max(0, 100 - d['wear'])}%")
        print(f"Power On Hours:                     {d['poh']:,}")
        print(f"Data Units Written:                 {d['lba_written'] // 1000:,}")
        print("Media and Data Integrity Errors:    0")
        print("")
        print("Self-test Log (NVMe Log 0x06)")
        print("Num  Test_Description  Status                       Power_on_Hours")
        print(f"   0  Extended          Completed without error                {d['poh']}")
        return 0

    print("=== START OF INFORMATION SECTION ===")
    print(f"Device Model:     {d['model']}")
    print(f"Serial Number:    {d['serial']}")
    print(f"User Capacity:    {d['size']} bytes")
    print("Rotation Rate:    Solid State Device")
    print("")
    print("=== START OF READ SMART DATA SECTION ===")
    print("SMART overall-health self-assessment test result: PASSED")
    print("")
    print("Vendor Specific SMART Attributes with Thresholds:")
    print("ID# ATTRIBUTE_NAME          FLAG     VALUE WORST THRESH TYPE      UPDATED  WHEN_FAILED RAW_VALUE")
    print(f"  5 Reallocated_Sector_Ct   0x0033   100   100   010    Pre-fail  Always       -       {d['realloc']}")
    print(f"  9 Power_On_Hours          0x0032   099   099   000    Old_age   Always       -       {d['poh']}")
    print(f"177 Wear_Leveling_Count     0x0013   {d['wear']:03d}   {d['wear']:03d}   005    Pre-fail  Always       -       1")
    print(f"197 Current_Pending_Sector  0x0012   100   100   000    Old_age   Always       -       {d['pending']}")
    print(f"241 Total_LBAs_Written      0x0032   099   099   000    Old_age   Always       -       {d['lba_written']}")
    print("")
    print("SMART Self-test log structure revision number 1")
    print("Num  Test_Description    Status                  Remaining  LifeTime(hours)  LBA_of_first_error")
    print(f"# 1  Extended offline    Completed without error       00%      {d['poh']}         -")
    return 0


if __name__ == "__main__":
    sys.exit(main())
